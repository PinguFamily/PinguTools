<Window
    x:Class="PinguTools.Controls.DiagnosticsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:PinguTools.Behaviors"
    xmlns:common="clr-namespace:PinguTools.Common;assembly=PinguTools.Common"
    xmlns:controls="clr-namespace:PinguTools.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:localization="clr-namespace:PinguTools.Localization"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding Title}"
    MaxWidth="800"
    MaxHeight="600"
    d:DataContext="{d:DesignInstance controls:DiagnosticsWindowViewModel}"
    SizeToContent="WidthAndHeight"
    Style="{DynamicResource DialogWindowStyle}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <Style TargetType="{x:Type TextBlock}" x:Key="WrapText">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid
            Margin="8"
            AlternationCount="1000"
            AutoGenerateColumns="False"
            ItemsSource="{Binding Diagnostics}"
            RowDetailsVisibilityMode="VisibleWhenSelected"
            ScrollViewer.CanContentScroll="True"
            ScrollViewer.HorizontalScrollBarVisibility="Auto"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="40" Header="#">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock HorizontalAlignment="Center"
                                       Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type DataGridRow}}, Path=AlternationIndex}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Width="12" Height="12">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Severity}"
                                                         Value="{x:Static common:DiagnosticSeverity.Error}">
                                                <Setter Property="Source" Value="{StaticResource ErrorIcon}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}"
                                                         Value="{x:Static common:DiagnosticSeverity.Warning}">
                                                <Setter Property="Source" Value="{StaticResource WarningIcon}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Severity}"
                                                         Value="{x:Static common:DiagnosticSeverity.Information}">
                                                <Setter Property="Source" Value="{StaticResource InfoIcon}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn
                    Width="*"
                    ElementStyle="{StaticResource WrapText}"
                    IsReadOnly="True"
                    Binding="{Binding Message}"
                    Header="{x:Static localization:Strings.Label_Message}" />
            </DataGrid.Columns>

            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <controls:ObjectTreeView SelectedObject="{Binding Target}" />
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
        </DataGrid>


        <Expander
            Grid.Row="2"
            Margin="8,0,8,8"
            Header="{x:Static localization:Strings.Label_StackTrace}">
            <i:Interaction.Behaviors>
                <behaviors:HideIfNullValueBehavior Value="{Binding StackTrace}" />
            </i:Interaction.Behaviors>
            <TextBox
                Height="150"
                Margin="0,8,0,0"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                FontFamily="Consolas, Courier New"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                Text="{Binding StackTrace}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto" />
        </Expander>

        <StackPanel
            Grid.Row="3"
            Margin="8"
            HorizontalAlignment="Right">
            <Button
                MinWidth="60"
                Content="OK"
                IsDefault="True">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Click">
                        <i:CallMethodAction MethodName="Close"
                                            TargetObject="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>
        </StackPanel>
    </Grid>
</Window>