<UserControl
    d:DataContext="{d:DesignInstance Type=viewModels:StageTabViewModel}"
    mc:Ignorable="d"
    x:Class="PinguTools.Pages.StageTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PinguTools.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
    xmlns:viewModels="clr-namespace:PinguTools.ViewModels"
    xmlns:localization="clr-namespace:PinguTools.Localization">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel.Resources>
                <Style TargetType="{x:Type local:FilePicker}">
                    <Setter Property="Filter" Value="{x:Static localization:FileFilterStrings.Image}" />
                    <Setter Property="Margin" Value="0,4,0,0" />
                </Style>
            </StackPanel.Resources>
            <local:FilePicker
                Label="{x:Static localization:Strings.Label_Background}"
                Margin="0,0,0,0"
                Path="{Binding BackgroundPath}"
                Required="True" />

            <GroupBox Header="{x:Static localization:Strings.Label_Stage_ID}" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <xctk:IntegerUpDown Minimum="0" Value="{Binding StageId, Mode=TwoWay}" />
                    <TextBlock
                        Margin="2,0,0,0"
                        Text="{Binding StageId, StringFormat=[stage{0:000000}], Mode=OneWay}"
                        VerticalAlignment="Center" />
                </StackPanel>

            </GroupBox>

            <GroupBox Header="{x:Static localization:Strings.Label_Effects}" Margin="0,4,0,0">
                <StackPanel Orientation="Vertical">
                    <local:FilePicker Margin="0,0,0,0" Path="{Binding EffectPath0}" />
                    <local:FilePicker Path="{Binding EffectPath1}" />
                    <local:FilePicker Path="{Binding EffectPath2}" />
                    <local:FilePicker Path="{Binding EffectPath3}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static localization:Strings.Label_NotesField_Line_Color}" Margin="0,4,0,0">
                <ComboBox ItemsSource="{Binding AssetManager.FieldLines}"
                          SelectedItem="{Binding NoteFieldsLine, Mode=TwoWay}" />
            </GroupBox>
        </StackPanel>

        <StackPanel Grid.Row="1" Style="{StaticResource ActionPanelStyle}">
            <Button
                Command="{Binding ClearAllCommand}"
                Content="{x:Static localization:Strings.Button_Clear}"
                Margin="0,0,4,0"
                Style="{StaticResource ActionButton}" />
            <Button
                Command="{Binding ActionCommand}"
                Content="{x:Static localization:Strings.Button_Generate}"
                Style="{StaticResource ActionButton}" />
        </StackPanel>
    </Grid>
</UserControl>