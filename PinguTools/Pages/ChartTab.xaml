<UserControl
    d:DataContext="{d:DesignInstance Type=viewModels:ChartTabViewModel}"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="PinguTools.Pages.ChartTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PinguTools.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="clr-namespace:PinguTools.ViewModels"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:PinguTools.Behaviors"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:localization="clr-namespace:PinguTools.Localization">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <local:FilePicker
                Filter="{x:Static localization:FileFilterStrings.Mgxc}"
                Label="{x:Static localization:Strings.Label_Input}"
                Path="{Binding ChartPath}"
                Required="True" />

            <GroupBox Header="{x:Static localization:Strings.Label_Information}" Margin="0,4,0,0">
                <Grid>
                    <local:MetaPropertyGrid SelectedObject="{Binding Model}">
                        <local:MetaPropertyGrid.Whitelist>
                            <system:String>Designer</system:String>
                            <system:String>Difficulty</system:String>
                            <system:String>Id</system:String>
                            <system:String>MainBpm</system:String>
                            <system:String>BgmEnableBarOffset</system:String>
                        </local:MetaPropertyGrid.Whitelist>
                        <b:Interaction.Behaviors>
                            <behaviors:HideIfNullValueBehavior Value="{Binding Model}" />
                        </b:Interaction.Behaviors>
                    </local:MetaPropertyGrid>
                    <TextBlock
                        FontStyle="Italic"
                        HorizontalAlignment="Center"
                        Text="{x:Static localization:Strings.Label_Not_Available}"
                        VerticalAlignment="Center">
                        <b:Interaction.Behaviors>
                            <behaviors:HideIfNullValueBehavior Value="{Binding Model}" Invert="True" />
                        </b:Interaction.Behaviors>
                    </TextBlock>
                </Grid>
            </GroupBox>
        </StackPanel>


        <StackPanel Grid.Row="1" Style="{StaticResource ActionPanelStyle}">
            <Button
                Command="{Binding ActionCommand}"
                Content="{x:Static localization:Strings.Button_Convert}"
                Style="{StaticResource ActionButton}" />
        </StackPanel>
    </Grid>
</UserControl>